# Independent commercial site preview.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3100

# Use either a Stripe Payment Link or full Checkout session credentials.
# The Payment Link path is fastest for MVP launch.
STRIPE_PAYMENT_LINK_URL=
