# Project environment template.
# Copy to .env only for local overrides. Never commit real secrets.

# Fixed local nodes for this project.
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8003

# Frontend API base. Keep this aligned with the fixed backend node.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8003/api
API_PROXY_TARGET=http://127.0.0.1:8003/api

# Backend CLI/API clients.
AGENT_API_BASE=http://127.0.0.1:8003/api
