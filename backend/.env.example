# LLM defaults
# Supported providers: zhipu, bailian, deepseek, openai
LLM_PROVIDER=bailian
LLM_MODEL=qwen3.5-plus
LLM_API_KEY=your_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# Zhipu / BigModel
ZHIPU_API_KEY=your_key
ZHIPUAI_API_KEY=your_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5

# Bailian / DashScope
BAILIAN_API_KEY=your_key
DASHSCOPE_API_KEY=your_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible embeddings defaults
# Supported providers: bailian, openai
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_API_KEY=your_key
EMBEDDING_BASE_URL=

# Retrieval backends
VECTOR_STORE_BACKEND=qdrant
DOCUMENT_CONVERSION_BACKEND=docling
RETRIEVAL_CORE_BACKEND=llamaindex
DOCLING_ENABLED=true
DOCLING_PREFER_OCR=false

# RAG data roots. Defaults to ../langchain-agent-data, outside the code project.
APP_EXTERNAL_DATA_ROOT=
APP_KNOWLEDGE_ROOT=
APP_INDEXES_ROOT=
APP_DOCUMENT_CACHE_ROOT=
APP_MODALITY_ARTIFACTS_ROOT=

# Qdrant defaults
# Leave QDRANT_URL empty to use embedded local Qdrant storage under storage/indexes/<collection>/dense
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=agent

FAISS_METRIC=cosine
FAISS_INDEX_TYPE=hnsw
FAISS_HNSW_M=32
FAISS_HNSW_EF_CONSTRUCTION=40
FAISS_HNSW_EF_SEARCH=64

# OpenAI embeddings
OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Rerank defaults
# RERANK_ENABLED=false -> always use heuristic rerank
# Local model rerank:
#   RERANK_PROVIDER=cross_encoder
#   RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Remote Bailian rerank:
#   RERANK_PROVIDER=bailian
#   RERANK_MODEL=qwen3-rerank
#   RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   RERANK_API_KEY=sk-xxxx
RERANK_ENABLED=false
RERANK_PROVIDER=heuristic
RERANK_MODEL=
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_TOP_N=200
RERANK_CANDIDATE_POOL=200
RERANK_DEVICE=

# Tavily web search
TAVILY_API_KEY=your_key
TAVILY_PROJECT=

# Optional MinerU PDF parsing API
# Modes:
# - local_sync: local mineru-api service, e.g. http://127.0.0.1:8000 + /file_parse
# - cloud_v4_batch: official cloud batch API, e.g. https://mineru.net + /api/v4/file-urls/batch
MINERU_API_ENABLED=false
MINERU_API_MODE=local_sync
MINERU_API_BASE_URL=http://127.0.0.1:8000
MINERU_API_PARSE_PATH=/file_parse
MINERU_API_KEY=
MINERU_API_TIMEOUT_SECONDS=180

# Official cloud example:
# MINERU_API_ENABLED=true
# MINERU_API_MODE=cloud_v4_batch
# MINERU_API_BASE_URL=https://mineru.net
# MINERU_API_PARSE_PATH=/api/v4/file-urls/batch
# MINERU_API_KEY=your_token

# Soul visual asset generation (OpenAI-compatible image API)
SOUL_IMAGE_API_BASE_URL=https://www.aimapi.cloud/v1
SOUL_IMAGE_API_KEY=your_key
SOUL_IMAGE_MODEL=gpt-image-2
