# Backend environment template.
# Copy this file to backend/.env and fill only the providers you actually use.
# Keep real API keys out of git.

# LLM defaults
# Supported providers: zhipu, bailian, deepseek, openai
LLM_PROVIDER=bailian
LLM_MODEL=qwen3.5-plus
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional fallback LLM. Leave empty to disable fallback routing.
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=

# Optional reasoning controls.
# LLM_THINKING_MODE: disabled, enabled, or provider-supported value.
# LLM_REASONING_EFFORT: auto, low, medium, high, or provider-supported value.
LLM_THINKING_MODE=disabled
LLM_REASONING_EFFORT=auto

# Zhipu / BigModel
ZHIPU_API_KEY=
ZHIPUAI_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5

# Bailian / DashScope
BAILIAN_API_KEY=
DASHSCOPE_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional role-specific DeepSeek keys.
DEEPSEEK_WRITING_API_KEY=
DEEPSEEK_REVIEW_API_KEY=
DEEPSEEK_MEMORY_API_KEY=

# OpenAI-compatible chat and embeddings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Embeddings
# Supported providers: bailian, openai
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Retrieval backends
VECTOR_STORE_BACKEND=qdrant
DOCUMENT_CONVERSION_BACKEND=docling
RETRIEVAL_CORE_BACKEND=llamaindex
DOCLING_ENABLED=true
DOCLING_PREFER_OCR=false

# RAG data roots. Defaults resolve outside the code project when left empty.
APP_EXTERNAL_DATA_ROOT=
APP_KNOWLEDGE_ROOT=
APP_INDEXES_ROOT=
APP_DOCUMENT_CACHE_ROOT=
APP_MODALITY_ARTIFACTS_ROOT=
APP_STORAGE_ROOT=

# Qdrant defaults
# Leave QDRANT_URL empty to use embedded local Qdrant storage.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=agent

# FAISS defaults
FAISS_METRIC=cosine
FAISS_INDEX_TYPE=hnsw
FAISS_HNSW_M=32
FAISS_HNSW_EF_CONSTRUCTION=40
FAISS_HNSW_EF_SEARCH=64

# Rerank defaults
# RERANK_ENABLED=false -> use heuristic rerank.
# For local model rerank:
#   RERANK_PROVIDER=cross_encoder
#   RERANK_MODEL=BAAI/bge-reranker-v2-m3
# For remote Bailian rerank:
#   RERANK_PROVIDER=bailian
#   RERANK_MODEL=qwen3-rerank
#   RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_ENABLED=false
RERANK_PROVIDER=heuristic
RERANK_MODEL=
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_TOP_N=200
RERANK_CANDIDATE_POOL=200
RERANK_BATCH_SIZE=8
RERANK_MAX_LENGTH=512
RERANK_DEVICE=

# Optional RAG query rewrite.
RAG_QUERY_REWRITE_MODE=disabled
RAG_QUERY_REWRITE_MODEL=
RAG_QUERY_REWRITE_TIMEOUT_SECONDS=30

# Tavily web search
TAVILY_API_KEY=
TAVILY_PROJECT=

# Optional MinerU PDF parsing API
# Modes:
# - local_sync: local mineru-api service, e.g. http://127.0.0.1:8000 + /file_parse
# - cloud_v4_batch: official cloud batch API, e.g. https://mineru.net + /api/v4/file-urls/batch
MINERU_API_ENABLED=false
MINERU_API_MODE=local_sync
MINERU_API_BASE_URL=http://127.0.0.1:8000
MINERU_API_PARSE_PATH=/file_parse
MINERU_API_KEY=
MINERU_API_TIMEOUT_SECONDS=180

# Image asset generation (OpenAI-compatible image API)
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=
IMAGE_FALLBACK_MODELS=
IMAGE_REQUEST_TIMEOUT_SECONDS=150
IMAGE_REQUEST_RETRY_ATTEMPTS=2

# Optional local code environment integration.
CODE_ENVIRONMENT_PI_SOURCE_ROOT=
CODE_ENVIRONMENT_PI_CLI_PATH=

# Optional CLI / runtime controls.
AGENT_API_BASE=http://127.0.0.1:8003/api
AGENT_CLI_STATE_PATH=
# Defaults to 100; valid range is 1-100.
AGENT_SINGLE_TURN_TOOL_ITERATIONS=
LANGCHAIN_AGENT_BACKEND_DIR=
LANGCHAIN_AGENT_MCP_TRANSPORT=stdio
