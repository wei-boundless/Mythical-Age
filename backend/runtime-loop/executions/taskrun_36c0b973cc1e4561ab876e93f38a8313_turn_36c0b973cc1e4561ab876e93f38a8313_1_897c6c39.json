          "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>贪吃蛇 - Snake</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    background: #1a1a2e;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    height: 100vh;\n    font-family: 'Courier New', monospace;\n    overflow: hidden;\n  }\n  .game-wrapper {\n    text-align: center;\n  }\n  h1 {\n    color: #e94560;\n    font-size: 2rem;\n    margin-bottom: 8px;\n    letter-spacing: 4px;\n  }\n  .score-board {\n    color: #eee;\n    font-size: 1.1rem;\n    margin-bottom: 10px;\n    display: flex;\n    justify-content: center;\n    gap: 30px;\n  }\n  .score-board span { color: #f5c518; font-weight: bold; }\n  canvas {\n    border: 2px solid #e94560;\n    border-radius: 4px;\n    background: #16213e;\n    display: block;\n    margin: 0 auto;\n  }\n  .controls {\n    margin-top: 14px;\n    color: #888;\n    font-size: 0.9rem;\n  }\n  .controls kbd {\n    background: #333;\n    color: #eee;\n    border: 1px solid #555;\n    border-radius: 3px;\n    padding: 2px 7px;\n    margin: 0 2px;\n    font-family: inherit;\n  }\n  .restart-btn {\n    margin-top: 10px;\n    padding: 8px 28px;\n    font-size: 1rem;\n    background: #e94560;\n    color: #fff;\n    border: none;\n    border-radius: 4px;\n    cursor: pointer;\n    font-family: inherit;\n    letter-spacing: 2px;\n    transition: background 0.2s;\n  }\n  .restart-btn:hover { background: #c73652; }\n  .gameover-overlay {\n    color: #e94560;\n    font-size: 1.3rem;\n    margin-top: 8px;\n    display: none;\n  }\n</style>\n</head>\n<body>\n<div class=\"game-wrapper\">\n  <h1>SNAKE</h1>\n  <div class=\"score-board\">\n    得分: <span id=\"score\">0</span>\n    最高: <span id=\"best\">0</span>\n  </div>\n  <canvas id=\"canvas\" width=\"400\" height=\"400\"></canvas>\n  <div class=\"gameover-overlay\" id=\"gameover\">游戏结束 — 按 R 或点击按钮重新开始</div>\n  <button class=\"restart-btn\" id=\"restartBtn\">重新开始</button>\n  <div class=\"controls\">\n    <kbd>↑</kbd> <kbd>↓</kbd> <kbd>←</kbd> <kbd>→</kbd> 移动 &nbsp;|&nbsp; <kbd>R</kbd> 重新开始\n  </div>\n</div>\n\n<script>\n(function () {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n\n  const scoreEl = document.getElementById('score');\n  const bestEl = document.getElementById('best');\n  const gameoverEl = document.getElementById('gameover');\n  const restartBtn = document.getElementById('restartBtn');\n\n  const GRID = 20;          // 每格像素\n  const COLS = canvas.width / GRID;   // 20\n  const ROWS = canvas.height / GRID;  // 20\n\n  let snake, food, direction, nextDirection, score, best, gameLoop, gameRunning;\n\n  // --- 初始化 / 重置 ---\n  function init() {\n    // 蛇身：从中间偏左开始，初始长度 3\n    snake = [\n      { x: 8, y: 10 },\n      { x: 7, y: 10 },\n      { x: 6, y: 10 }\n    ];\n    direction = { x: 1, y: 0 };\n    nextDirection = { x: 1, y: 0 };\n    score = 0;\n    gameRunning = true;\n    gameoverEl.style.display = 'none';\n    updateScore();\n    placeFood();\n  }\n\n  function placeFood() {\n    const occupied = new Set(snake.map(s => s.x + ',' + s.y));\n    const free = [];\n    for (let x = 0; x < COLS; x++) {\n      for (let y = 0; y < ROWS; y++) {\n        if (!occupied.has(x + ',' + y)) free.push({ x, y });\n      }\n    }\n    if (free.length === 0) {\n      // 胜利（蛇填满整个网格）\n      endGame(true);\n      return;\n    }\n    food = free[Math.floor(Math.random() * free.length)];\n  }\n\n  // --- 主循环 ---\n  function step() {\n    if (!gameRunning) return;\n\n    // 应用方向（禁止反向）\n    if (\n      !(nextDirection.x === -direction.x && nextDirection.y === -direction.y &&\n        snake.length > 1)\n    ) {\n      direction = { ...nextDirection };\n    }\n\n    const head = {\n      x: snake[0].x + direction.x,\n      y: snake[0].y + direction.y\n    };\n\n    // 撞墙检测\n    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {\n      endGame(false);\n      return;\n    }\n\n    // 撞自己检测（排除尾部，因为尾部即将移走——除非吃到食物）\n    const willGrow = head.x === food.x && head.y === food.y;\n    const checkBody = willGrow ? snake : snake.slice(0, -1);\n    if (checkBody.some(s => s.x === head.x && s.y === head.y)) {\n      endGame(false);\n      return;\n    }\n\n    snake.unshift(head);\n\n    if (willGrow) {\n      score += 10;\n      updateScore();\n      placeFood();\n    } else {\n      snake.pop();\n    }\n\n    draw();\n  }\n\n  // --- 绘制 ---\n  function draw() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    // 网格线（淡）\n    ctx.strokeStyle = '#1e2d4a';\n    ctx.lineWidth = 0.5;\n    for (let x = 0; x <= COLS; x++) {\n      ctx.beginPath();\n      ctx.moveTo(x * GRID, 0);\n      ctx.lineTo(x * GRID, canvas.height);\n      ctx.stroke();\n    }\n    for (let y = 0; y <= ROWS; y++) {\n      ctx.beginPath();\n      ctx.moveTo(0, y * GRID);\n      ctx.lineTo(canvas.width, y * GRID);\n      ctx.stroke();\n    }\n\n    // 食物\n    ctx.fillStyle = '#f5c518';\n    ctx.beginPath();\n    ctx.arc(\n      food.x * GRID + GRID / 2,\n      food.y * GRID + GRID / 2,\n      GRID / 2 - 2,\n      0,\n      Math.PI * 2\n    );\n    ctx.fill();\n\n    // 蛇身\n    snake.forEach((seg, i) => {\n      const alpha = 1 - i * 0.03;\n      ctx.fillStyle = i === 0\n        ? '#e94560'\n        : `rgba(46, 204, 113, ${Math.max(alpha, 0.3)})`;\n      ctx.fillRect(seg.x * GRID + 1, seg.y * GRID + 1, GRID - 2, GRID - 2);\n    });\n  }\n\n  // --- 结束 ---\n  function endGame(won) {\n    gameRunning = false;\n    clearInterval(gameLoop);\n    gameoverEl.style.display = 'block';\n    gameoverEl.textContent = won ? '你赢了！ 按 R 重新开始' : '游戏结束 — 按 R 或点击按钮重新开始';\n    if (score > best) {\n      best = score;\n      bestEl.textContent = best;\n      try { localStorage.setItem('snake_best', best); } catch (e) {}\n    }\n    // 画最后一帧不变\n  }\n\n  function updateScore() {\n    scoreEl.textContent = score;\n  }\n\n  function startGame() {\n    clearInterval(gameLoop);\n    init();\n    draw();\n    gameLoop = setInterval(step, 120);\n  }\n\n  // --- 事件 ---\n  window.addEventListener('keydown', function (e) {\n    if (!gameRunning && e.key === 'r') {\n      e.preventDefault();\n      startGame();\n      return;\n    }\n    if (!gameRunning) return;\n    switch (e.key) {\n      case 'ArrowUp':    e.preventDefault(); nextDirection = { x: 0, y: -1 }; break;\n      case 'ArrowDown':  e.preventDefault(); nextDirection = { x: 0, y: 1 };  break;\n      case 'ArrowLeft':  e.preventDefault(); nextDirection = { x: -1, y: 0 }; break;\n      case 'ArrowRight': e.preventDefault(); nextDirection = { x: 1, y: 0 };  break;\n      case 'r': case 'R': e.preventDefault(); startGame(); break;\n    }\n  });\n\n  restartBtn.addEventListener('click', startGame);\n\n  // --- 启动 ---\n  best = parseInt(localStorage.getItem('snake_best') || '0', 10) || 0;\n  bestEl.textContent = best;\n  startGame();\n})();\n</script>\n</body>\n</html>\n"
        },
