          "commit_type": "session_message",
          "payload": {
            "session_id": "743bb3a5f8244628b2da565b4c8fee4d",
            "task_run_id": "taskrun:743bb3a5f8244628b2da565b4c8fee4d:turn:743bb3a5f8244628b2da565b4c8fee4d:11:14130e5e",
