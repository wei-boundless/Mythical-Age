ue_triage\",\n    \"task_family\": \"health\",\n    \"title\": \"健康问题分诊\",\n    \"input_contract_id\": \"HealthIssue\",\n    \"output_contract_id\": \"HealthTriageResult\",\n    \"default_agent_id\": \"agent:health:maintainer\",\n    \"default_workflow_id\": \"workflow.health.issue_triage\",\n    \"default_projection_template_id\": \"xuannv__health_maintainer\",\n    \"default_runtime_lane\": \"health_issue_read\",\n    \"default_memory_scope\": \"issue_local_readonly\",\n    \"enabled\": true,\n    \"metadata\": {}\n  },\n  \"binding\": {\n    \"binding_id\": \"binding:flow.health.issue_triage:agent:health:maintainer\",\n    \"task_id\": \"task-template:issue_triage\",\n    \"flow_id\": \"flow.health.issue_triage\",\n    \"agent_id\": \"agent:health:maintainer\",\n    \"agent_profile_id\": \"health_maintainer_agent\",\n    \"runtime_lane\": \"health_issue_read\",\n    \"projection_template_id\": \"xuannv__health_maintainer\",\n    \"skill_workflow_id\": \"workflow.health.issue_triage\",\n    \"memory_scope\": \"issue_local_readonly\",\n    \"output_contract_id\": \"HealthTriageResult\",\n    \"resource_policy_ref\": \"resource-policy:flow.health.issue_triage:preview\",\n    \"validation_state\": \"valid\",\n    \"diagnostics\": {\n      \"failures\": []\n    }\n  },\n  \"workflow\": {\n    \"workflow_id\": \"workflow.health.issue_triage\",\n    \"title\": \"健康问题分诊工作流\",\n    \"task_mode\": \"issue_triage\",\n    \"visible_skill_ids\": [\n      \"skill.health.issue_triage\",\n      \"skill.health.trace_reading\"\n    ],\n    \"steps\": [\n      {\n        \"step_id\": \"collect_refs\",\n        \"title\": \"收集问题证据引用\"\n      },\n      {\n        \"step_id\": \"classify_owner\",\n        \"title\": \"判断归属系统\"\n      },\n      {\n        \"step_id\": \"summarize_triage\",\n        \"title\": \"输出分诊结果\"\n      }\n    ],\n    \"input_boundary\": \"HealthIssue + explicit trace refs only.\",\n    \"output_boundary\": \"HealthTriageResult candidate.\",\n    \"stop_conditions\": [\n      \"owner_system_identified\",\n      \"needs_evidence_marked\"\n    ],\n    \"required_evidence_refs\": [\n      \"conversation_ref\",\n      \"runtime_trace_refs\"\n    ],\n    \"output_contract_id\": \"HealthTriageResult\"\n  },\n  \"projection_instance\": {\n    \"projection_id\": \"projection:xuannv__health_maintainer:fea3c94263ce\",\n    \"template_id\": \"xuannv__health_maintainer\",\n    \"task_id\": \"task.health.issue_triage:health:issue:sample-task-system-chain\",\n    \"task_run_id\": \"taskrun:health-system:task.health.issue_triage:health:issue:sample-task-system-chain:de5dd33c\",\n    \"agent_id\": \"agent:health:maintainer\",\n    \"agent_profile_id\": \"health_maintainer_agent\",\n    \"runtime_lane\": \"health_issue_read\",\n    \"prompt_manifest_id\": \"prompt-manifest:projection:xuannv__health_maintainer:fea3c94263ce\",\n    \"resource_policy_ref\": \"resource-policy:flow.health.issue_triage:preview\",\n    \"context_snapshot_ref\": \"\",\n    \"created_at\": 1777523114.3875058,\n    \"metadata\": {\n      \"preview_only\": false,\n      \"soul_id\": \"xuannv\",\n      \"role_type\": \"health_inspector\"\n    }\n  }\n}"}], "history_message_count": 0, "pending_user_message_chars": 3652, "system_prompt_chars": 437, "memory_runtime_view_ref": "health-memory-view:health:issue:sample-task-system-chain:issue_triage", "projection_ref": "projection:xuannv__health_maintainer:fea3c94263ce", "prompt_manifest_ref": "prompt-manifest:projection:xuannv__health_maintainer:fea3c94263ce", "token_pressure": {"level": "unknown", "source": "health_system"}}, "context_policy_preview": {"memory_scope": "issue_local_readonly", "allowed_context_sections": ["health_issue", "runtime_trace", "prompt_manifest", "assertions"]}}, "refs": {"memory_runtime_view_ref": "health-memory-view:health:issue:sample-task-system-chain:issue_triage", "context_snapshot_ref": "ctx:taskrun:health-system:task.health.issue_triage:health:issue:sample-task-system-chain:de5dd33c", "projection_ref": "projection:xuannv__health_maintainer:fea3c94263ce", "prompt_manifest_ref": "prompt-manifest:projection:xuannv__health_maintainer:fea3c94263ce"}, "authority": "orchestration.runtime_event"}
