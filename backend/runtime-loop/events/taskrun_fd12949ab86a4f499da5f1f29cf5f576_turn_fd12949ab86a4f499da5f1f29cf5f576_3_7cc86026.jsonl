": [], "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-3c4f4650687e80ce", "task_id": "turn:fd12949ab86a4f499da5f1f29cf5f576:3", "soul_id": "runtime", "projection_id": "3c4f4650687e80ce", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:fd12949ab86a4f499da5f1f29cf5f576:3", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 132, "source_refs": ["task-prompt:turn:fd12949ab86a4f499da5f1f29cf5f576:3:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:fd12949ab86a4f499da5f1f29cf5f576:3", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 48, "source_refs": ["turn:fd12949ab86a4f499da5f1f29cf5f576:3"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:fd12949ab86a4f499da5f1f29cf5f576:3", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 76, "source_refs": ["task-prompt:turn:fd12949ab86a4f499da5f1f29cf5f576:3:runtime"], "candidate_refs": []}], "prompt_hash": "a5b7149e2126b6a7a709f6cbccd2ce8f7c6ec4ed984eec83252f23afb1f05a84", "total_sections": 3, "total_chars": 256}, "projection_requirement": {"task_id": "turn:fd12949ab86a4f499da5f1f29cf5f576:3", "role_type": "analyst", "posture_tags": ["concise"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visible_section_count": 3, "visible_tool_ids": [], "visible_skill_ids": [], "diagnostics": {"projection_owner": "SoulSystem", "cycle_owner": "TaskRunLoop", "context_snapshot_ref": "", "permission_expansion_allowed": false, "control_plane_sections_filtered": true}, "authority": "orchestration.s