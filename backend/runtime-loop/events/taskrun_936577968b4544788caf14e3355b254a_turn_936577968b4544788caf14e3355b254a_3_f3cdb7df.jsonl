uired inputs are already present, execute the relevant capability and return the result directly instead of asking for confirmation.", "source_refs": ["task-prompt:turn:936577968b4544788caf14e3355b254a:3:runtime"], "candidate_refs": [], "chars": 219}], "visible_skill_ids": [], "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-3712a5bab4d738b2", "task_id": "turn:936577968b4544788caf14e3355b254a:3", "soul_id": "runtime", "projection_id": "3712a5bab4d738b2", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:936577968b4544788caf14e3355b254a:3", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 228, "source_refs": ["task-prompt:turn:936577968b4544788caf14e3355b254a:3:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:936577968b4544788caf14e3355b254a:3", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 72, "source_refs": ["turn:936577968b4544788caf14e3355b254a:3"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:936577968b4544788caf14e3355b254a:3", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 219, "source_refs": ["task-prompt:turn:936577968b4544788caf14e3355b254a:3:runtime"], "candidate_refs": []}], "prompt_hash": "cc229556363295b80cce782397c5b9534ae1b6b9ffb5df06c53b819abce5ea2b", "total_sections": 3, "total_chars": 519}, "projection_requirement": {"task_id": "turn:936577968b4544788caf14e3355b254a:3", "role_type": "operator", "posture_tags": ["direct-execution", "result-first"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"