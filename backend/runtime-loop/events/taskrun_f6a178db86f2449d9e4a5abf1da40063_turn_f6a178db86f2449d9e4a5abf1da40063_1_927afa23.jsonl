, "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-2156589f66ae40b8", "task_id": "turn:f6a178db86f2449d9e4a5abf1da40063:1", "soul_id": "runtime", "projection_id": "2156589f66ae40b8", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:f6a178db86f2449d9e4a5abf1da40063:1", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 127, "source_refs": ["task-prompt:turn:f6a178db86f2449d9e4a5abf1da40063:1:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:f6a178db86f2449d9e4a5abf1da40063:1", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 48, "source_refs": ["turn:f6a178db86f2449d9e4a5abf1da40063:1"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:f6a178db86f2449d9e4a5abf1da40063:1", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 76, "source_refs": ["task-prompt:turn:f6a178db86f2449d9e4a5abf1da40063:1:runtime"], "candidate_refs": []}], "prompt_hash": "20b55cae4e9e6bbbf7f4b5abef08af493e592eaa2d67328e8679c70e142117f4", "total_sections": 3, "total_chars": 251}, "projection_requirement": {"task_id": "turn:f6a178db86f2449d9e4a5abf1da40063:1", "role_type": "analyst", "posture_tags": ["concise"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visible_section_count": 3, "visible_tool_ids": [], "visible_skill_ids": [], "diagnostics": {"projection_owner": "SoulSystem", "cycle_owner": "TaskRunLoop", "context_snapshot_ref": "", "permission_expansion_allowed": false, "control_plane_sections_filtered": true}, "authority": "orchestration.stage_