ons\": [\n      \"owner_system_identified\",\n      \"needs_evidence_marked\"\n    ],\n    \"required_evidence_refs\": [\n      \"conversation_ref\",\n      \"runtime_trace_refs\"\n    ],\n    \"output_contract_id\": \"HealthTriageResult\"\n  },\n  \"projection_instance\": {\n    \"projection_id\": \"projection:xuannv__health_maintainer:2be1933c8729\",\n    \"template_id\": \"xuannv__health_maintainer\",\n    \"task_id\": \"task.health.issue_triage:health:issue:sample-task-system-chain\",\n    \"task_run_id\": \"taskrun:health-system:task.health.issue_triage:health:issue:sample-task-system-chain:0e6867f7\",\n    \"agent_id\": \"agent:health:maintainer\",\n    \"agent_profile_id\": \"health_maintainer_agent\",\n    \"runtime_lane\": \"health_issue_read\",\n    \"prompt_manifest_id\": \"prompt-manifest:projection:xuannv__health_maintainer:2be1933c8729\",\n    \"resource_policy_ref\": \"resource-policy:flow.health.issue_triage:preview\",\n    \"context_snapshot_ref\": \"\",\n    \"created_at\": 1777550546.2047713,\n    \"metadata\": {\n      \"preview_only\": false,\n      \"soul_id\": \"xuannv\",\n      \"role_type\": \"health_inspector\"\n    }\n  }\n}"}], "history_message_count": 0, "pending_user_message_chars": 3652, "system_prompt_chars": 437, "memory_runtime_view_ref": "health-memory-view:health:issue:sample-task-system-chain:issue_triage", "projection_ref": "projection:xuannv__health_maintainer:2be1933c8729", "prompt_manifest_ref": "prompt-manifest:projection:xuannv__health_maintainer:2be1933c8729", "token_pressure": {"level": "unknown", "source": "health_system"}}, "context_policy_preview": {"memory_scope": "issue_local_readonly", "allowed_context_sections": ["health_issue", "runtime_trace", "prompt_manifest", "assertions"]}}, "refs": {"memory_runtime_view_ref": "health-memory-view:health:issue:sample-task-system-chain:issue_triage", "context_snapshot_ref": "ctx:taskrun:health-system:task.health.issue_triage:health:issue:sample-task-system-chain:0e6867f7", "pro