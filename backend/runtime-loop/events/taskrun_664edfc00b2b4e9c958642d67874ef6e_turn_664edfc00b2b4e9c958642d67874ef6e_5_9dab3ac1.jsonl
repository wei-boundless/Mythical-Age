": [], "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-063334d94adaab2d", "task_id": "turn:664edfc00b2b4e9c958642d67874ef6e:5", "soul_id": "runtime", "projection_id": "063334d94adaab2d", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:664edfc00b2b4e9c958642d67874ef6e:5", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 132, "source_refs": ["task-prompt:turn:664edfc00b2b4e9c958642d67874ef6e:5:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:664edfc00b2b4e9c958642d67874ef6e:5", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 48, "source_refs": ["turn:664edfc00b2b4e9c958642d67874ef6e:5"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:664edfc00b2b4e9c958642d67874ef6e:5", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 76, "source_refs": ["task-prompt:turn:664edfc00b2b4e9c958642d67874ef6e:5:runtime"], "candidate_refs": []}], "prompt_hash": "761e6bdb16d54c1ea0f0e425aaa41014440d3a4f46e63d0eb655ad1dbb8b1481", "total_sections": 3, "total_chars": 256}, "projection_requirement": {"task_id": "turn:664edfc00b2b4e9c958642d67874ef6e:5", "role_type": "analyst", "posture_tags": ["concise"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visible_section_count": 3, "visible_tool_ids": [], "visible_skill_ids": [], "diagnostics": {"projection_owner": "SoulSystem", "cycle_owner": "TaskRunLoop", "context_snapshot_ref": "", "permission_expansion_allowed": false, "control_plane_sections_filtered": true}, "authority": "orchestration.s