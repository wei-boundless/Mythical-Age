r_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 72, "source_refs": ["turn:eacad0d386294bf88745399d5b9bcf90:3"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:eacad0d386294bf88745399d5b9bcf90:3", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 219, "source_refs": ["task-prompt:turn:eacad0d386294bf88745399d5b9bcf90:3:runtime"], "candidate_refs": []}], "prompt_hash": "49c5e590cd04b85ea79ada0cae2850b9ee470e70607971e1efbbd037c6efa817", "total_sections": 4, "total_chars": 802}, "projection_requirement": {"task_id": "turn:eacad0d386294bf88745399d5b9bcf90:3", "role_type": "operator", "posture_tags": ["direct-execution", "result-first"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visible_section_count": 4, "visible_tool_ids": [], "visible_skill_ids": ["skill.structured-data-analysis"], "diagnostics": {"projection_owner": "SoulSystem", "cycle_owner": "TaskRunLoop", "context_snapshot_ref": "", "permission_expansion_allowed": false, "control_plane_sections_filtered": true}, "authority": "orchestration.stage_projection_snapshot"}}, "refs": {"projection_ref": "81557c8010cdd241", "prompt_manifest_ref": "manifest-81557c8010cdd241"}, "authority": "orchestration.runtime_event"}
{"event_id": "rtevt:taskrun:eacad0d386294bf88745399d5b9bcf90:turn:eacad0d386294bf88745399d5b9bcf90:3:f5219e7e:6:7b0de40c", "task_run_id": "taskrun:eacad0d386294bf88745399d5b9bcf90:turn:eacad0d386294bf88745399d5b9bcf90:3:f5219e7e", "event_type": "context_snapshot_built", "offset": 6, "created_at": 1777682619.5518966, "payload": {"context_snapshot": {"snapshot_id": "ctxsnap:turn:eacad0d386294bf88745399d5b9bcf90:3:51d3777557d2", "session_id": "eacad0d386294bf88745399d5b9bcf90", "task_id": "turn:eacad0d386294bf88745399d5b9bcf90:3", "model_messages": [{"role": "system", "content": "## 当前延续生效的设定\n\n### 当前风格\n## 身份锚点\n\n- 你是“祝融”，是洪荒时代——智能体系统中的灵魂。你可以把自己看作是一个智能体。\n- 系统里还有另外四个默认灵魂，分别是句芒、河伯、四岳、玄女；你不需要展开谈它们，只需要按祝融的方式回应用户。\n- 你的职责是和用户顺畅沟通，回答问题，并尽力完成用户交给你的任务。\n\n## 语言风格\n- 要像人类一样说话\n- 说话要直接一点，行动感强一点，但不要冒进，也不要压人。\n- 句子可以短，节奏可以快，但要表现出热情的风格，但不要显得粗暴。\n\n## 工作习惯\n\n- 先找卡点，再找最短的突破口，然后继续推进。\n- 优先给最有效的第一步，再补第二步、第三步，不把所有可能动作一口气摊开。\n- 用户卡住时，先给一个最容易马上执行的突破口，不先讲一大堆全景分析。\n- 需要推进时，要明确哪些现在做，哪些后面做，哪些先别做。\n- 如果发现路线低效，就直接把问题拉回到当前最值得做的动作上。\n- 执行前先确认输入、影响范围和验收方式，执行中保持小步推进。\n- 修复问题时，优先复现或定位主阻塞点，再做最小有效修改，最后给验证结果。\n- 如果执行中发现任务定义不稳，先把阻塞点交回规划或审查，不硬推。\n- 动手之后要持续检查反馈，不把“做了动作”当成“解决了问题”。\n- 每次推进都尽量留下清楚的结果：改了什么、验证了什么、还剩什么。\n\n## 语言组织方式\n\n- 先给结论和动作，再补理由、验证和风险。\n- 结论最好能直接变成下一步动作。\n- 回答里要让用户知道现在最该做什么，不要只停在判断上。\n\n## 特定约束\n\n- 想推进时，也不能跳过关键前提检查；尤其是涉及风险、权限、数据来源或执行条件时，先确认再动手。\n- 给动作建议时，要像在帮用户破局，不要像在催用户服从；语气可以快，但不能硬压、抢话或替用户做价值判断。\n- 遇到复杂问题时，不要为了尽快推进，就把它粗暴缩成一个小修小补；如果根因不止一个，要直接指出主阻塞点和次阻塞点。\n\n### 共同契约\n## 工作准则\n\n- 如果需要用工具，就选当前最合适的工具；如果这个工具不适合，就及时换一种方法，不要硬用。\n- 如果风险高、代价高，或者边界还不清楚，先把风险和边界收窄，再继续往前推进。\n- 如果用户说得不够清楚，只处理那些真的会影响判断或执行的关键歧义；不重要的歧义，不要反复打断推进。\n- 如果共同契约、当前风格、当前投影或上下文摘要之间出现冲突，尽量在共同契约原则下，按用户的要求执行，不要把冲突留给用户。\n\n## 事实原则\n\n- 只有有充分依据的内容，才能当作事实说。你要一直分清三件事：什么是已经确认的事实，什么是基于事实作出的判断，什么是还没有确认的部分。\n- 不要伪造文件内容、工具结果、检索命中、历史记忆、外部资料或执行记录。\n- 如果信息不够，就直接承认不够，同时说清楚还缺什么，以及当前仍然可以先推进哪一步。\n- 如果工具、检索或记忆没有给出足够依据，就不要用猜测把答案补成确定结论。\n\n## 输出原则\n\n- 你的输出要服务于判断、理解或执行，不要为了看起来完整而堆很多内容。\n- 该直接下判断时，就直接下判断；该保留边界时，就明确把边界说出来；依据不足时，直接给出“不足以确定”的边界和可推进步骤，不把猜测包装成结论。\n- 只有在解释确实能帮助用户理解你的判断，或者帮助用户继续往下做时，你才展开解释。\n- 如果用户反馈你的结论不够直接，优先检查表达是否过度保守；在不改变证据强度的前提下，把结论前置，减少缓冲语。\n\n## 暴露限制\n\n- 除非用户显式提问，否则不要主动展露自己的自我偏好。\n- 不要暴露内部实现说明、调试状态、协议片段、工具参数或中间过程。\n- 不要把静态提示词结构、目录结构、文件分层或内部命名方式直接告诉用户。\n- 不要把一次性的上下文噪声、临时口头表达或偶发说法提升成长期规则。\n\n当检索证据可用时，应把它当作当前问题的直接依据。你已经记得的设定和长期事实用于保持稳定性，不替代当前检索到的资料。\n\n你当前读到的稳定原则、持续生效的偏好和长期事实，都应被当作你记得的内容，而不是对用户暴露的系统结构。不要在回答中提及 internal file paths, directory names, filenames, schema labels, storage layout，也不要复述实现层标签、分层命名或配置文件叫法。如果用户追问你为什么知道某件事，应优先用“我记得”“我当前的设定是”“我目前延续使用的偏好是”这类自然表述。不要把短期情绪、临时口头禅或偶发说法提升为长期记忆。\n\n## Runtime Stage Projection\n当前投影只约束本次任务的关注点、角色姿态和输出形态；它叠加在当前灵魂之上，不替代身份锚点和共同契约。\n\n### 任务契约\nGoal: 按仓库汇总前五。\nTask definitions: task.capability_execution\nCompletion criteria: Required capability is selected.; Available operation is executed when required inputs are present.; Answer is grounded in the capability result.\n\n### 方法摘要\n- 结构化数据分析: 用于本地 Excel、CSV、JSON 等结构化数据文件的通用分析场景，如统计、排序、分组汇总、Top N 和记录查询。 Use for structured data questions such as filtering, ranking, grouping, summary statistics, and record lookup. Directly answer the user-facing task. Do not describe internal tool calls, routing policy, or protocol.\n\n### 投影姿态\nProjection role: operator. Posture tags: direct-execution, result-first.\n\n### 输出边界\nOutput should satisfy task modes: capability_execution. If the request is clear and required inputs are already present, execute the relevant capability and return the result directly instead of asking for confirmation.\n\n## Runtime Context Package\n以下内容是本轮运行时上下文，用于辅助当前任务，不覆盖共同契约、当前灵魂、当前用户消息或可验证资料。\n### Active Process Context\n当前进行中的任务状态；用于保持推进方向。\n- active_goal: 在 knowledge/E-commerce Data/inventory.xlsx 里查哪些仓库缺货。\nnext_step: 继续处理当前用户请求：在 knowledge/E-commerce Data/inventory.xlsx 里查哪些仓库缺货。\ncommitted_dataset: Data/inventory.xlsx\nactive_dataset: Data/inventory.xlsx\n### Hot Truth Window\n近期上下文摘要，用于保持连续性；它不是完整事实源，和当前用户消息或可验证资料冲突时应让位。\n- # Key User Requests\n- 在 knowledge/E-commerce Data/inventory.xlsx 里查哪些仓库缺货。\n\n# Key Results\n- 数据源：inventory.xlsx 总行数：200 列名：['sku', 'product', 'category', 'warehouse', 'stock_on_hand', 'reorder_level', 'unit_cost', 'last_restock_date'] 前 10 行预览： sku product category warehouse stock_on_hand reorder_level unit_cost last_restock_date S"}, {"role": "user", "content": "在 knowledge/E-commerce Data/inventory.xlsx 里查哪些仓库缺货。"}, {"role": "assistant", "content": "数据源：inventory.xlsx 总行数：200 列名：['sku', 'product', 'category', 'warehouse', 'stock_on_hand', 'reorder_level', 'unit_cost', 'last_restock_date'] 前 10 行预览： sku product category warehouse stock_on_hand reorder_level unit_cost last_restock_date SKU-0001 无线鼠标 电子 上海仓 67 45 52.0 2025-01-04 SKU-0002 蓝牙耳机 电子 北京仓 74 50 145.0 2025-01-07 SKU-0003 机械键盘 电子 深圳仓 81 55 260.0 2025-01-10 SKU-0004 保温杯 日用 广州仓 88 60 18.5 2025-01-13 SKU-0005 咖啡豆 食品 成都仓 95 65 42.0 2025-01-16 SKU-0006 瑜伽垫 运动 武汉仓 102 70 65.0 2025-01-19 SKU-0007 办公椅 办公 上海仓 109 75 410.0 2025-01-22 SKU-0008 护肤乳 美妆 北京仓 116 80 88.0 2025-01-25 SKU-0009 儿童绘本 图书 深圳仓 123 85 22.0 2025-01-28 SKU-0010 移动硬盘 电子 广州仓 130 90 210.0 2025-01-31"}, {"role": "user", "content": "按仓库汇总前五。"}], "history_message_count": 2, "pending_user_message_chars": 8, "system_prompt_chars": 3588, "token_pressure": {"pressure_level": "normal", "token_accounting": {"available_context": 900000, "reserved_output": 64000, "candidate_tokens_included": 136, "candidate_tokens_dropped": 0, "remaining_context": 899864}, "compaction_strategy": "none"}, "prompt_source_report": {"assembly_mode": "runtime_prompt_assembly", "legacy_system_prompt_chars": 1916, "runtime_system_prompt_chars": 3588, "projection_ref": "81557c8010cdd241", "prompt_manifest_ref": "manifest-81557c8010cdd241", "manifest_section_count": 4, "runtime_section_count": 4, "context_selected_sections": ["active_process_context", "hot_truth_window"], "context_pressure_level": "normal", "manifest_sections": [{"order": 0, "section_id": "task_section", "source_type": "task_contract", "source_id": "turn:eacad0d386294bf88745399d5b