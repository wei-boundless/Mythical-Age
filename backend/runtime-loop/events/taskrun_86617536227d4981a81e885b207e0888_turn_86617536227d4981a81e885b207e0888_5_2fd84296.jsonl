": [], "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-7bb0b5977552f5dd", "task_id": "turn:86617536227d4981a81e885b207e0888:5", "soul_id": "runtime", "projection_id": "7bb0b5977552f5dd", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:86617536227d4981a81e885b207e0888:5", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 132, "source_refs": ["task-prompt:turn:86617536227d4981a81e885b207e0888:5:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:86617536227d4981a81e885b207e0888:5", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 48, "source_refs": ["turn:86617536227d4981a81e885b207e0888:5"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:86617536227d4981a81e885b207e0888:5", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 76, "source_refs": ["task-prompt:turn:86617536227d4981a81e885b207e0888:5:runtime"], "candidate_refs": []}], "prompt_hash": "8bce13771c8fee45272235b552c7f17aae57d178f57e5df0ac8d1a440fc5b031", "total_sections": 3, "total_chars": 256}, "projection_requirement": {"task_id": "turn:86617536227d4981a81e885b207e0888:5", "role_type": "analyst", "posture_tags": ["concise"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visible_section_count": 3, "visible_tool_ids": [], "visible_skill_ids": [], "diagnostics": {"projection_owner": "SoulSystem", "cycle_owner": "TaskRunLoop", "context_snapshot_ref": "", "permission_expansion_allowed": false, "control_plane_sections_filtered": true}, "authority": "orchestration.s