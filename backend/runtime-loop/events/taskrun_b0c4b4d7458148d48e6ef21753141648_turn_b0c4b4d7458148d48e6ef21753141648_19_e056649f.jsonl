{"event_id": "rtevt:taskrun:b0c4b4d7458148d48e6ef21753141648:turn:b0c4b4d7458148d48e6ef21753141648:19:e056649f:5:8172814a", "task_run_id": "taskrun:b0c4b4d7458148d48e6ef21753141648:turn:b0c4b4d7458148d48e6ef21753141648:19:e056649f", "event_type": "stage_projection_built", "offset": 5, "created_at": 1777644752.7756422, "payload": {"stage_projection": {"snapshot_id": "stageproj:turn:b0c4b4d7458148d48e6ef21753141648:19:8b9a36176b78", "task_id": "turn:b0c4b4d7458148d48e6ef21753141648:19", "projection_ref": "1103ea81667a9648", "prompt_manifest_ref": "manifest-1103ea81667a9648", "soul_runtime_view": {"soul_id": "runtime", "role_type": "analyst", "task_mode": "task.request_intake", "sections": [{"section_id": "task_section", "title": "任务契约", "source_type": "task_contract", "source_id": "turn:b0c4b4d7458148d48e6ef21753141648:19", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "content": "Goal: 你为什么不调用工具呢，你可以调用哪些工具\nTask definitions: task.request_intake\nCompletion criteria: User goal is captured.; No execution is performed.", "source_refs": ["task-prompt:turn:b0c4b4d7458148d48e6ef21753141648:19:runtime"], "candidate_refs": [], "chars": 136}, {"section_id": "projection_section", "title": "投影姿态", "source_type": "projection_requirement", "source_id": "turn:b0c4b4d7458148d48e6ef21753141648:19", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "content": "Projection role: analyst. Posture tags: concise.", "source_refs": ["turn:b0c4b4d7458148d48e6ef21753141648:19"], "candidate_refs": [], "chars": 48}, {"section_id": "output_section", "title": "输出边界", "source_type": "task_contract", "source_id": "turn:b0c4b4d7458148d48e6ef21753141648:19", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "content": "Output should satisfy task modes: request_intake. Return a concise response.", "source_refs": ["task-prompt:turn:b0c4b4d7458148d48e6ef21753141648:19:runtime"], "candidate_refs": [], "chars": 76}], "vis