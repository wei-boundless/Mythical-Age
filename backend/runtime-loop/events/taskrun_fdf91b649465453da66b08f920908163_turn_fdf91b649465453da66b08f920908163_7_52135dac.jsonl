{"event_id": "rtevt:taskrun:fdf91b649465453da66b08f920908163:turn:fdf91b649465453da66b08f920908163:7:52135dac:6:7457f75e", "task_run_id": "taskrun:fdf91b649465453da66b08f920908163:turn:fdf91b649465453da66b08f920908163:7:52135dac", "event_type": "stage_projection_built", "offset": 6, "created_at": 1777693110.6285667, "payload": {"stage_projection": {"snapshot_id": "stageproj:turn:fdf91b649465453da66b08f920908163:7:94f764a2eef9", "task_id": "turn:fdf91b649465453da66b08f920908163:7", "projection_ref": "a46b9bb521edcd35", "prompt_manifest_ref": "manifest-a46b9bb521edcd35", "soul_runtime_view": {"soul_id": "runtime", "role_type": "operator", "task_mode": "task.capability_execution", "sections": [{"section_id": "task_section", "title": "任务契约", "source_type": "task_contract", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "content": "Goal: 你是谁\nTask definitions: task.capability_execution\nCompletion criteria: Required capability is selected.; Available operation is executed when required inputs are present.; Answer is grounded in the capability result.", "source_refs": ["task-prompt:turn:fdf91b649465453da66b08f920908163:7:runtime"], "candidate_refs": [], "chars": 220}, {"section_id": "projection_section", "title": "投影姿态", "source_type": "projection_requirement", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "content": "Projection role: operator. Posture tags: direct-execution, result-first.", "source_refs": ["turn:fdf91b649465453da66b08f920908163:7"], "candidate_refs": [], "chars": 72}, {"section_id": "output_section", "title": "输出边界", "source_type": "task_contract", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "content": "Output should satisfy task modes: capability_execution. If the request is clear and required inputs are already present, execute the relevant capability and return the result directly instead of asking for confirmation.", "source_refs": ["task-prompt:turn:fdf91b649465453da66b08f920908163:7:runtime"], "candidate_refs": [], "chars": 219}], "visible_skill_ids": [], "visible_tool_ids": [], "authorization_owner": "ResourcePolicy", "trace": {"projection_owner": "SoulRuntimeProjection", "authorization_owner": "ResourcePolicy"}}, "prompt_manifest": {"manifest_id": "manifest-a46b9bb521edcd35", "task_id": "turn:fdf91b649465453da66b08f920908163:7", "soul_id": "runtime", "projection_id": "a46b9bb521edcd35", "sections": [{"section_id": "task_section", "source_type": "task_contract", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 220, "source_refs": ["task-prompt:turn:fdf91b649465453da66b08f920908163:7:runtime"], "candidate_refs": []}, {"section_id": "projection_section", "source_type": "projection_requirement", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "projection", "cache_scope": "dynamic", "visible_to_model": true, "chars": 72, "source_refs": ["turn:fdf91b649465453da66b08f920908163:7"], "candidate_refs": []}, {"section_id": "output_section", "source_type": "task_contract", "source_id": "turn:fdf91b649465453da66b08f920908163:7", "owner_layer": "task", "cache_scope": "dynamic", "visible_to_model": true, "chars": 219, "source_refs": ["task-prompt:turn:fdf91b649465453da66b08f920908163:7:runtime"], "candidate_refs": []}], "prompt_hash": "a410a636065119ce7dbbe73b6c0f1f546f66ce459148a47a03364d9a78da7ef0", "total_sections": 3, "total_chars": 511}, "projection_requirement": {"task_id": "turn:fdf91b649465453da66b08f920908163:7", "role_type": "operator", "posture_tags": ["direct-execution", "result-first"], "expression_density": "normal", "attention_focus": ["task_goal", "method", "output"], "reason": "derived from task binding and selected definitions"}, "visi