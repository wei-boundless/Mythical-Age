          "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>点灯快手 - Tap The Light</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    background: #0f0f1a;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    height: 100vh;\n    font-family: 'Segoe UI', 'PingFang SC', sans-serif;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .game-wrapper {\n    text-align: center;\n    max-width: 420px;\n    width: 100%;\n  }\n  h1 {\n    color: #ff6b35;\n    font-size: 2rem;\n    margin-bottom: 6px;\n    letter-spacing: 3px;\n  }\n  .status-bar {\n    display: flex;\n    justify-content: center;\n    gap: 36px;\n    margin-bottom: 16px;\n  }\n  .stat {\n    color: #ccc;\n    font-size: 1.05rem;\n  }\n  .stat .val {\n    color: #ffba08;\n    font-weight: 700;\n    font-size: 1.35rem;\n    margin-left: 4px;\n  }\n  .grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px;\n    width: 320px;\n    margin: 0 auto 18px;\n  }\n  .cell {\n    width: 70px;\n    height: 70px;\n    background: #1e1e3a;\n    border: 2px solid #2e2e5a;\n    border-radius: 12px;\n    cursor: pointer;\n    transition: background 0.10s, border-color 0.10s, transform 0.08s, box-shadow 0.10s;\n    position: relative;\n  }\n  .cell.lit {\n    background: #ff6b35;\n    border-color: #ff8c5a;\n    box-shadow: 0 0 22px rgba(255,107,53,0.7);\n    transform: scale(1.06);\n    animation: pulse 0.55s ease-in-out infinite alternate;\n  }\n  .cell.lit:active {\n    transform: scale(0.94);\n    background: #ffd166;\n    box-shadow: 0 0 32px rgba(255,209,102,0.9);\n  }\n  .cell.miss-flash {\n    background: #e63946 !important;\n    border-color: #ff4757 !important;\n    box-shadow: 0 0 16px rgba(230,57,70,0.7) !important;\n    animation: none !important;\n  }\n  @keyframes pulse {\n    from { box-shadow: 0 0 14px rgba(255,107,53,0.5); }\n    to   { box-shadow: 0 0 28px rgba(255,107,53,0.9); }\n  }\n  .start-btn {\n    padding: 10px 40px;\n    font-size: 1.1rem;\n    font-weight: 700;\n    background: #ff6b35;\n    color: #fff;\n    border: none;\n    border-radius: 8px;\n    cursor: pointer;\n    letter-spacing: 2px;\n    transition: background 0.18s, transform 0.10s;\n  }\n  .start-btn:hover { background: #e85d2c; }\n  .start-btn:active { transform: scale(0.96); }\n  .start-btn:disabled {\n    background: #444;\n    color: #888;\n    cursor: not-allowed;\n  }\n  .message {\n    margin-top: 14px;\n    font-size: 1.15rem;\n    font-weight: 600;\n    min-height: 28px;\n    transition: color 0.2s;\n  }\n  .message.fail { color: #e63946; }\n  .message.warn { color: #ffba08; }\n  .message.info { color: #aaa; }\n  .worker-indicator {\n    margin-top: 8px;\n    font-size: 0.78rem;\n    color: #555;\n  }\n  .worker-indicator .dot {\n    display: inline-block;\n    width: 8px; height: 8px;\n    border-radius: 50%;\n    margin-right: 4px;\n    background: #555;\n  }\n  .worker-indicator .dot.alive { background: #2ecc71; }\n  .worker-indicator .dot.dead  { background: #e63946; }\n</style>\n</head>\n<body>\n<div class=\"game-wrapper\">\n  <h1>点灯快手</h1>\n  <div class=\"status-bar\">\n    <div class=\"stat\">得分 <span class=\"val\" id=\"score\">0</span></div>\n    <div class=\"stat\">失误 <span class=\"val\" id=\"misses\">0</span>/3</div>\n  </div>\n  <div class=\"grid\" id=\"grid\"></div>\n  <button class=\"start-btn\" id=\"startBtn\">开始游戏</button>\n  <div class=\"message info\" id=\"message\">按「开始游戏」或空格键开始</div>\n  <div class=\"worker-indicator\">\n    <span class=\"dot\" id=\"workerDot\"></span>\n    Worker: <span id=\"workerStatus\">未启动</span>\n  </div>\n</div>\n\n<script>\n(function () {\n  // ── DOM refs ────────────────────────────────\n  const gridEl     = document.getElementById('grid');\n  const scoreEl    = document.getElementById('score');\n  const missesEl   = document.getElementById('misses');\n  const startBtn   = document.getElementById('startBtn');\n  const messageEl  = document.getElementById('message');\n  const workerDot  = document.getElementById('workerDot');\n  const workerStat = document.getElementById('workerStatus');\n\n  const CELL_COUNT = 16; // 4x4\n  let cells = [];\n  let worker = null;\n  let gameActive = false;\n\n  // ── Build grid ──────────────────────────────\n  for (let i = 0; i < CELL_COUNT; i++) {\n    const div = document.createElement('div');\n    div.className = 'cell';\n    div.dataset.index = i;\n    div.addEventListener('click', () => onCellClick(i));\n    gridEl.appendChild(div);\n    cells.push(div);\n  }\n\n  // ── Worker blob ─────────────────────────────\n  const workerScript = `\n    // ── Game State Machine (runs in Worker) ──\n    const CELL_COUNT = 16;\n    const MAX_MISSES = 3;\n    const MIN_INTERVAL = 600;  // ms between activations\n    const MAX_INTERVAL = 1400;\n    const LIT_DURATION = 800;  // ms a cell stays lit\n\n    let score = 0;\n    let misses = 0;\n    let activeIndex = -1;\n    let spawnTimer = null;\n    let decayTimer = null;\n    let running = false;\n\n    function randomCell() {\n      return Math.floor(Math.random() * CELL_COUNT);\n    }\n\n    function spawnTarget() {\n      if (!running) return;\n\n      // Pick a cell different from current active\n      let idx = randomCell();\n      if (CELL_COUNT > 1) {\n        while (idx === activeIndex) idx = randomCell();\n      }\n      activeIndex = idx;\n      postMessage({ type: 'activate', index: idx });\n\n      // Set decay timer\n      decayTimer = setTimeout(() => {\n        if (!running || activeIndex !== idx) return;\n        // Miss: player failed to click in time\n        misses++;\n        activeIndex = -1;\n        postMessage({ type: 'score', score, misses });\n        postMessage({ type: 'deactivate', index: idx, reason: 'timeout' });\n\n        if (misses >= MAX_MISSES) {\n          endGame('timeout');\n        } else {\n          scheduleNext();\n        }\n      }, LIT_DURATION);\n    }\n\n    function scheduleNext() {\n      if (!running) return;\n      const delay = MIN_INTERVAL + Math.random() * (MAX_INTERVAL - MIN_INTERVAL);\n      spawnTimer = setTimeout(spawnTarget, delay);\n    }\n\n    function endGame(reason) {\n      running = false;\n      clearTimeout(spawnTimer);\n      clearTimeout(decayTimer);\n      postMessage({ type: 'gameOver', reason, score, misses });\n    }\n\n    self.onmessage = function (e) {\n      const msg = e.data;\n      switch (msg.type) {\n        case 'start':\n          score = 0;\n          misses = 0;\n          activeIndex = -1;\n          running = true;\n          clearTimeout(spawnTimer);\n          clearTimeout(decayTimer);\n          postMessage({ type: 'score', score, misses });\n          scheduleNext();\n          break;\n\n        case 'click':\n          if (!running) break;\n          if (msg.index === activeIndex) {\n            // Hit!\n            score++;\n            clearTimeout(decayTimer);\n            postMessage({ type: 'deactivate', index: activeIndex, reason: 'hit' });\n            activeIndex = -1;\n            postMessage({ type: 'score', score, misses });\n            scheduleNext();\n          } else {\n            // Wrong cell\n            misses++;\n            postMessage({ type: 'score', score, misses });\n            postMessage({ type: 'missFlash', index: msg.index });\n            if (misses >= MAX_MISSES) {\n              endGame('wrong_click');\n            }\n          }\n          break;\n\n        case 'stop':\n          endGame('stopped');\n          break;\n      }\n    };\n  `;\n\n  const blob = new Blob([workerScript], { type: 'application/javascript' });\n  const workerUrl = URL.createObjectURL(blob);\n\n  function spawnWorker() {\n    if (worker) {\n      worker.terminate();\n    }\n    try {\n      worker = new Worker(workerUrl);\n      worker.onmessage = handleWorkerMessage;\n      worker.onerror = function (err) {\n        console.error('Worker error:', err);\n        setWorkerStatus(false, '错误');\n        messageEl.textContent = 'Worker 运行出错';\n        messageEl.className = 'message fail';\n      };\n      setWorkerStatus(true, '运行中');\n    } catch (e) {\n      console.error('Worker spawn failed:', e);\n      setWorkerStatus(false, '启动失败');\n      messageEl.textContent = 'Worker 创建失败，请检查浏览器支持';\n      messageEl.className = 'message fail';\n    }\n  }\n\n  function setWorkerStatus(alive, text) {\n    workerDot.className = 'dot ' + (alive ? 'alive' : 'dead');\n    workerStat.textContent = text;\n  }\n\n  // ── Handle messages from worker ─────────────\n  function handleWorkerMessage(e) {\n    const msg = e.data;\n\n    switch (msg.type) {\n      case 'activate':\n        cells[msg.index].classList.add('lit');\n        break;\n\n      case 'deactivate':\n        cells[msg.index].classList.remove('lit');\n        break;\n\n      case 'score':\n        scoreEl.textContent = msg.score;\n        missesEl.textContent = msg.misses;\n        break;\n\n      case 'missFlash':\n        cells[msg.index].classList.add('miss-flash');\n        setTimeout(() => cells[msg.index].classList.remove('miss-flash'), 220);\n        break;\n\n      case 'gameOver':\n        gameActive = false;\n        messageEl.textContent = '游戏结束！' +\n          (msg.reason === 'timeout' ? ' 灯灭了没点到' :\n           msg.reason === 'wrong_click' ? ' 点错了格子' :\n           msg.reason === 'stopped' ? ' 已停止' : '');\n        messageEl.className = 'message fail';\n        startBtn.disabled = false;\n        setWorkerStatus(false, '已结束');\n        // Clear all lit cells\n        cells.forEach(c => c.classList.remove('lit'));\n        break;\n    }\n  }\n\n  // ── Cell click handler ──────────────────────\n  function onCellClick(index) {\n    if (!gameActive) return;\n    if (!worker) return;\n    worker.postMessage({ type: 'click', index });\n  }\n\n  // ── Start / restart ─────────────────────────\n  function startGame() {\n    // Clear state\n    cells.forEach(c => c.classList.remove('lit', 'miss-flash'));\n    scoreEl.textContent = '0';\n    missesEl.textContent = '0';\n    messageEl.textContent = '游戏中… 快速点击亮起的格子！';\n    messageEl.className = 'message info';\n    startBtn.disabled = true;\n\n    if (!worker) {\n      spawnWorker();\n      if (!worker) return;\n    }\n    gameActive = true;\n    setWorkerStatus(true, '运行中');\n    worker.postMessage({ type: 'start' });\n  }\n\n  // ── Events ──────────────────────────────────\n  startBtn.addEventListener('click', startGame);\n  window.addEventListener('keydown', function (e) {\n    if (e.code === 'Space') {\n      e.preventDefault();\n      if (!gameActive) startGame();\n    }\n  });\n\n  // ── Init ────────────────────────────────────\n  setWorkerStatus(false, '未启动');\n})();\n</script>\n</body>\n</html>\n"
        },
