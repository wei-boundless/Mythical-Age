      "text": "# 领域目录索引：E-commerce Data",
      "modality": "text",
      "section_label": "领域目录索引：E-commerce Data",
      "structure_role": "heading",
      "page": null,
      "section_path": [
        "领域目录索引：E-commerce Data"
      ],
